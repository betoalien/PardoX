{
    "name": "betoalien/pardox-php",
    "description": "High-Performance DataFrame Engine powered by Rust (The PardoX Project)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "dataframe",
        "rust",
        "ffi",
        "data-analysis",
        "etl",
        "performance",
        "pandas",
        "database"
    ],
    "authors": [
        {
            "name": "Alberto Cardenas",
            "email": "iam@albertocardenas.com",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "PardoX\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/betoalien/pardox-php/issues",
        "source": "https://github.com/betoalien/pardox-php"
    }
}
